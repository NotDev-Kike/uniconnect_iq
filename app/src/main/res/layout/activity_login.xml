<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F19"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UniConnect IQ"
        android:textColor="#38BDF8"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inicia sesión para activar VoIP y Rastreo"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111827"
        android:orientation="vertical"
        android:padding="20dp"
        android:elevation="4dp">

        <EditText
            android:id="@+id/etLoginCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Correo Institucional"
            android:inputType="textEmailAddress"
            android:textColor="#F8FAFC"
            android:textColorHint="#64748B"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contraseña"
            android:inputType="textPassword"
            android:textColor="#F8FAFC"
            android:textColorHint="#64748B"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnLoginIngresar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INGRESAR AL SISTEMA"
            android:backgroundTint="#38BDF8"
            android:textColor="#0F172A"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvIrARegistro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿No tienes cuenta? Regístrate aquí"
            android:textColor="#38BDF8"
            android:textSize="14sp"
            android:layout_gravity="center_horizontal"
            android:padding="8dp"/>
    </LinearLayout>
</LinearLayout>