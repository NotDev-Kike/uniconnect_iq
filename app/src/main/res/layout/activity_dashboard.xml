<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F19">

    <!-- ScrollView principal -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvUserInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Usuario: Cargando..."
                android:textColor="#38BDF8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:id="@+id/tvDashExtension"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado: Verificando registro..."
                android:textColor="#94A3B8"
                android:textSize="16sp"
                android:layout_marginBottom="20dp"/>

            <EditText
                android:id="@+id/etDestinoVoip"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:hint="Número de Extensión"
                android:inputType="number"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#64748B"
                android:backgroundTint="#38BDF8"/>

            <Button
                android:id="@+id/btnLlamarVoip"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:text="INICIAR LLAMADA"
                android:textSize="18sp"
                android:backgroundTint="#10B981"
                android:layout_marginTop="15dp"/>

            <Button
                android:id="@+id/btnActivarIA"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:text="LLAMAR POR VOZ (IA)"
                android:textSize="18sp"
                android:backgroundTint="#8B5CF6"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="25dp"/>

            <!-- WebView ajustado -->
            <WebView
                android:id="@+id/webViewRadar"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginBottom="25dp"
                android:background="#000000" />

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:text="CERRAR SESIÓN"
                android:textSize="18sp"
                android:backgroundTint="#EF4444"
                android:layout_marginTop="10dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Layout de llamada encima de todo -->
    <LinearLayout
        android:id="@+id/layoutLlamadaActiva"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#0B0F19"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Llamada en curso"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:layout_marginBottom="40dp"/>

        <Button android:id="@+id/btnContestar" android:layout_width="match_parent" android:layout_height="90dp" android:text="CONTESTAR" android:textSize="20sp" android:visibility="gone" android:backgroundTint="#10B981" android:layout_marginBottom="20dp"/>
        <Button android:id="@+id/btnAltavoz" android:layout_width="match_parent" android:layout_height="90dp" android:text="ALTAVOZ" android:textSize="20sp" android:backgroundTint="#64748B" android:layout_marginBottom="20dp"/>
        <Button android:id="@+id/btnColgar" android:layout_width="match_parent" android:layout_height="90dp" android:text="COLGAR" android:textSize="20sp" android:backgroundTint="#EF4444"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>