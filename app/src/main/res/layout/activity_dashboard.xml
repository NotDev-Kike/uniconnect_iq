<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F19">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvUserInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Usuario: Cargando..."
                android:textColor="#38BDF8"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:id="@+id/tvDashExtension"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado: Verificando registro..."
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <EditText
                android:id="@+id/etDestinoVoip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número de Extensión"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#64748B"/>

            <Button
                android:id="@+id/btnLlamarVoip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="INICIAR LLAMADA"
                android:backgroundTint="#10B981"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CERRAR SESIÓN"
                android:backgroundTint="#EF4444"/>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutLlamadaActiva"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#0B0F19"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Llamada en curso"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:layout_marginBottom="30dp"/>

        <Button android:id="@+id/btnContestar" android:layout_width="250dp" android:layout_height="wrap_content" android:text="CONTESTAR" android:visibility="gone" android:backgroundTint="#10B981"/>
        <Button android:id="@+id/btnAltavoz" android:layout_width="250dp" android:layout_height="wrap_content" android:text="ALTAVOZ" android:backgroundTint="#64748B"/>
        <Button android:id="@+id/btnColgar" android:layout_width="250dp" android:layout_height="wrap_content" android:text="COLGAR" android:backgroundTint="#EF4444"/>
    </LinearLayout>
</RelativeLayout>