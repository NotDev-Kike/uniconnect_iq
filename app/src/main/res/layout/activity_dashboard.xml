<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F19"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvUserInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#38BDF8"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvDashExtension"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#94A3B8"
        android:textSize="16sp"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvUserInfo"/>

    <EditText
        android:id="@+id/etDestinoVoip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Número de Extensión"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textColorHint="#64748B"
        android:backgroundTint="#38BDF8"
        app:layout_constraintTop_toBottomOf="@id/tvDashExtension"/>

    <Button
        android:id="@+id/btnLlamarVoip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="INICIAR LLAMADA"
        android:backgroundTint="#10B981"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/etDestinoVoip"/>

    <Button
        android:id="@+id/btnActivarIA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LLAMAR POR VOZ (IA)"
        android:backgroundTint="#8B5CF6"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/btnLlamarVoip"/>

    <WebView
        android:id="@+id/webViewRadar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="#000000"
        app:layout_constraintTop_toBottomOf="@id/btnActivarIA"
        app:layout_constraintBottom_toTopOf="@id/btnCerrarSesion"/>

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CERRAR SESIÓN"
        android:backgroundTint="#EF4444"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Layout de llamada -->
    <LinearLayout
        android:id="@+id/layoutLlamadaActiva"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#0B0F19"
        android:gravity="center"
        android:orientation="vertical">
        <Button android:id="@+id/btnContestar" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CONTESTAR" android:backgroundTint="#10B981" android:layout_marginBottom="20dp"/>
        <Button android:id="@+id/btnColgar" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="COLGAR" android:backgroundTint="#EF4444"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>